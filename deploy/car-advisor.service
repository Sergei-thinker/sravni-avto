[Unit]
Description=Car Advisor FastAPI Backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/car-advisor/backend
EnvironmentFile=/opt/car-advisor/backend/.env
ExecStart=/opt/car-advisor/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
